{
  "version": 2,
  "routes": [
    {
      "src": "/favicon.png",
      "headers": { "Content-Type": "image/png" },
      "dest": "/favicon.png"
    },
    {
      "src": "/robots.txt",
      "headers": { "Content-Type": "text/plain" },
      "dest": "/robots.txt"
    },
    {
      "src": "/sitemap.xml",
      "headers": { "Content-Type": "application/xml" },
      "dest": "/sitemap.xml"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}